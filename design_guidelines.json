  "instructions_to_main_agent": [
    "INSTALL: lenis framer-motion clsx tailwind-merge @radix-ui/react-slot lucide-react",
    "SETUP: Configure Tailwind with custom colors (brand-primary: #D4FF00, brand-bg: #0a0a0a).",
    "FONTS: Import 'Syne' and 'Space Grotesk' from Google Fonts immediately.",
    "LAYOUT: Use a strict grid. Avoid rounded corners on buttons/cards - keep it brutalist.",
    "CRITICAL: Do NOT use default rounded-lg on cards. Override Shadcn defaults to rounded-none.",
    "NAVIGATION: Create a 'Mega Menu' for the shop categories.",
    "WHATSAPP: Add a floating WhatsApp button (fixed bottom-right, z-50) using pure SVG/Lucide icon.",
    "MAP: Use a dark-themed map iframe for the Store Locator page.",
    "TESTING: Add data-testid to all interactive elements (buttons, inputs, links)."
  ],
  "universal_guidelines": [
    "Do not use gradients for backgrounds, use solid dark colors with noise textures.",
    "Use 24px-32px blur for glassmorphism.",
    "Ensure 3:1 contrast ratio for all text.",
    "Mobile-first: Stack grids to 1 column on mobile, 4 on desktop.",
    "Use 'group' and 'group-hover' tailwind classes for card hover effects."
  ]
}