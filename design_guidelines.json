{
  "brand_identity": {
    "name": "Bad Monkey",
    "ethos": "The Street Never Sleeps.",
    "vibe": "Urban Brutalist Luxury",
    "target_audience": "Sneakerheads, Hypebeasts, Gen Z (18-35)",
    "core_values": [
      "Authenticity",
      "Edgy",
      "Street-First",
      "High-Energy"
    ]
  },
  "design_system": {
    "theme": {
      "mode": "dark",
      "strategy": "Brutalist Dark Mode with Neon Accents"
    },
    "colors": {
      "base": {
        "background": "#0a0a0a",
        "surface": "#121212",
        "foreground": "#fafafa",
        "border": "#27272a"
      },
      "brand": {
        "primary": "#D4FF00",
        "secondary": "#FF3B30",
        "accent": "#00E0FF"
      },
      "neutral": {
        "100": "#f5f5f5",
        "500": "#737373",
        "900": "#171717"
      }
    },
    "typography": {
      "headings": {
        "font_family": "Syne, sans-serif",
        "weights": [700, 800],
        "tracking": "-0.02em",
        "casing": "uppercase"
      },
      "subheadings": {
        "font_family": "Space Grotesk, monospace",
        "weights": [500],
        "tracking": "0.05em",
        "casing": "uppercase"
      },
      "body": {
        "font_family": "Inter, sans-serif",
        "weights": [400, 500],
        "line_height": "1.6"
      }
    },
    "layout": {
      "container_max_width": "1600px",
      "grid_columns": 12,
      "spacing_scale": {
        "section_y": "py-24 md:py-32",
        "element_gap": "gap-6 md:gap-12"
      },
      "border_radius": {
        "buttons": "0px",
        "cards": "0px",
        "inputs": "0px"
      }
    }
  },
  "visual_enhancers": {
    "textures": [
      "noise-overlay",
      "grid-lines"
    ],
    "effects": [
      "glitch-on-hover",
      "marquee-scrolling",
      "parallax-scroll"
    ],
    "motion": {
      "library": "framer-motion",
      "scroll": "lenis",
      "defaults": {
        "duration": 0.4,
        "ease": "[0.22, 1, 0.36, 1]"
      }
    }
  },
  "components": {
    "navbar": {
      "style": "Sticky, Glassmorphism (Backdrop Blur)",
      "elements": ["Logo (Left)", "Nav Links (Center)", "Cart/Search (Right)"],
      "background": "bg-black/80 backdrop-blur-md border-b border-white/10"
    },
    "hero": {
      "style": "Full-screen immersive with massive typography overlay",
      "content": "Video background or High-Res Urban Image with 'Glitch' text effect"
    },
    "product_card": {
      "style": "Raw Industrial",
      "features": [
        "No border radius (sharp edges)",
        "1px solid border (zinc-800)",
        "Image aspect ratio 4:5",
        "Hover: Image Swap or Zoom",
        "Price tag: Neon background with Black text"
      ]
    },
    "buttons": {
      "primary": "bg-[#D4FF00] text-black hover:bg-white hover:text-black uppercase font-bold tracking-wider rounded-none px-8 py-4 transition-all",
      "secondary": "border border-white/20 text-white hover:bg-white hover:text-black uppercase tracking-wider rounded-none px-8 py-4 transition-all"
    },
    "marquee": {
      "text": "BAD MONKEY • EST 2023 • BENGALURU • LIMITED DROPS • WORLDWIDE SHIPPING •",
      "style": "bg-white text-black py-3 font-bold uppercase tracking-widest text-sm"
    }
  },
